# ccv-hub shared deployment template

# Web public entry
CCV_HUB_PUBLIC_PROTOCOL=https
CCV_HUB_PUBLIC_HOST=ccv-hub-dev.paas.996667.xyz
CCV_HUB_PUBLIC_DOMAIN=paas.996667.xyz
CCV_HUB_PUBLIC_DOMAIN_REGEX=paas\.996667\.xyz
CCV_HUB_VIEWER_SUBDOMAIN_PREFIX=ccv-

# Web container / adapter
CCV_HUB_WEB_PORT=4317
CCV_HUB_WEB_IMAGE=ccv-hub-web:v0.0.0-dev
CCV_HUB_AGENT_UPSTREAM=http://host.docker.internal:4318
CCV_HUB_DOCKER_NETWORK=dokploy-network

# Agent runtime
CCV_HUB_HOST=0.0.0.0
CCV_HUB_PORT=4318
CCV_HUB_AUTH_PASSWORD=change-me
CCV_HUB_SESSION_SECRET=change-me-to-a-long-random-secret
CCV_HUB_AGENT_PROXY_TOKEN=change-me-to-a-random-secret
CCV_HUB_PATH_ROOTS=/home/opc/projects
CCV_CLI_PATH=/home/opc/projects/ccvs/cc-viewer/cli.js
CLAUDE_CONFIG_DIR=/home/opc/.claude
HOME=/home/opc
LOG_LEVEL=info
