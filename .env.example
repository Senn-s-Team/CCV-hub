# ccv-hub Web deployment template

# Web public entry
CCV_HUB_PUBLIC_PROTOCOL=https
CCV_HUB_PUBLIC_HOST=ccv-hub-dev.paas.s3n.top
CCV_HUB_VIEWER_PATH_PREFIX=/viewer
# Optional: set only for a dedicated parent domain that should share panel sessions.
# CCV_HUB_COOKIE_DOMAIN=.paas.s3n.top

# Web container / adapter
CCV_HUB_WEB_PORT=4317
CCV_HUB_WEB_IMAGE=ccv-hub-web:vX.Y.Z
CCV_HUB_AGENT_UPSTREAM=http://host.docker.internal:4318
CCV_HUB_AGENT_PROXY_TOKEN=change-me-to-a-random-secret
CCV_HUB_WEB_ROOT=/var/www/ccv-hub/current
CCV_HUB_DOCKER_NETWORK=dokploy-network
