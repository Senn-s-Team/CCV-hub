{
  "name": "ccv-hub",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "bun run --workspaces build",
    "test": "bun run --workspaces test",
    "lint": "bun run --workspaces lint",
    "dev:web": "bun run --filter hub-web dev",
    "dev:service": "bun run --filter hub-service dev",
    "release:agent": "node scripts/package-agent-release.mjs",
    "release:web": "node scripts/package-web-release.mjs",
    "smoke:release": "node scripts/smoke-release.mjs",
    "deploy:service": "sudo install -m 0644 deploy/ccv-hub-agent.service /etc/systemd/system/ccv-hub-agent.service && sudo systemctl daemon-reload && sudo systemctl restart ccv-hub-agent && systemctl is-active ccv-hub-agent"
  },
  "devDependencies": {
    "@types/node": "24.7.2"
  }
}