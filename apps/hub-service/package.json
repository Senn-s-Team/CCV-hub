{
  "name": "hub-service",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "bun run --filter @ccv-hub/shared-contracts build && tsx watch src/server.ts",
    "build": "bun run --filter @ccv-hub/shared-contracts build && tsc -p tsconfig.json --noEmit false",
    "start": "node dist/server.js",
    "test": "bun run --filter @ccv-hub/shared-contracts build && vitest run",
    "lint": "bun run --filter @ccv-hub/shared-contracts build && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@ccv-hub/shared-contracts": "workspace:*",
    "fastify": "5.8.5",
    "pino": "10.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}