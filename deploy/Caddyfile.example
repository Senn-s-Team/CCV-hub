# [INPUT]: 依赖 Caddy、hub-web 静态产物目录、环境变量 CCV_HUB_PUBLIC_HOST/CCV_HUB_AGENT_UPSTREAM 与宿主机 ccv-hub-agent API/bridge 服务
# [OUTPUT]: 对外提供 Hub 主域名、/api 代理与同 host /viewer/* 反向代理样例
# [POS]: deploy 目录的 Caddy 平台适配模板，负责用自动 HTTPS 承载 Web 静态入口与 Agent bridge
# [PROTOCOL]: 变更时更新此头部，然后检查 CLAUDE.md
{
  servers {
    protocols h1 h2
  }
}

{$CCV_HUB_PUBLIC_HOST} {
  encode zstd gzip
  root * {$CCV_HUB_WEB_ROOT:/var/www/ccv-hub/current}

  handle /api/* {
    reverse_proxy {$CCV_HUB_AGENT_UPSTREAM:127.0.0.1:4318} {
      header_up X-CCV-Hub-Agent-Token {$CCV_HUB_AGENT_PROXY_TOKEN}
    }
  }

  handle {$CCV_HUB_VIEWER_PATH_PREFIX:/viewer}/* {
    reverse_proxy {$CCV_HUB_AGENT_UPSTREAM:127.0.0.1:4318} {
      header_up X-CCV-Hub-Agent-Token {$CCV_HUB_AGENT_PROXY_TOKEN}
      transport http {
        read_timeout 1h
      }
    }
  }

  handle {
    try_files {path} {path}/ /index.html
    file_server
  }
}
