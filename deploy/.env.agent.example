# [INPUT]: 依赖宿主机域名、路径 allowlist、cc-viewer CLI、Claude 配置目录、Hub 插件回连地址、显式插件安装开关与 Agent 鉴权密钥
# [OUTPUT]: 对外提供 /etc/ccv-hub/.env.agent 的 release 环境变量模板
# [POS]: deploy 目录的 Agent 环境模板，负责把 release systemd 单元中的本机差异收敛到一个可复制配置文件
# [PROTOCOL]: 变更时更新此头部，然后检查 CLAUDE.md

CCV_HUB_ENV=production
CCV_HUB_HOST=0.0.0.0
CCV_HUB_PORT=4318

CCV_HUB_PUBLIC_PROTOCOL=https
CCV_HUB_PUBLIC_HOST=ccv-hub-dev.paas.s3n.top
CCV_HUB_VIEWER_PATH_PREFIX=/viewer
CCV_HUB_URL=http://127.0.0.1:4318
# Optional: set only for a dedicated parent domain that should share panel sessions.
# CCV_HUB_COOKIE_DOMAIN=.example.com
CCV_HUB_PLUGIN_AUTO_INSTALL=0

CCV_HUB_AGENT_PROXY_TOKEN=change-me-to-a-random-secret
CCV_HUB_AUTH_PASSWORD=change-me
CCV_HUB_SESSION_SECRET=change-me-to-a-long-random-secret

CCV_HUB_PATH_ROOTS=/home/user/projects
CCV_CLI_PATH=/opt/cc-viewer/current/cli.js
CLAUDE_CONFIG_DIR=/home/user/.claude
HOME=/home/user
LOG_LEVEL=info
