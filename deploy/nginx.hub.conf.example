# [INPUT]: 依赖 Nginx、hub-web 静态产物目录与宿主机 ccv-hub-agent API/bridge 服务
# [OUTPUT]: 对外提供 Hub 静态站点、/api 代理与 viewer wildcard 反向代理样例
# [POS]: deploy 目录的 Nginx 平台适配模板，负责传统 VPS 静态 Web 与 Agent bridge 接入
# [PROTOCOL]: 变更时更新此头部，然后检查 CLAUDE.md
map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

server {
  listen 80;
  server_name hub.example.com;

  root /var/www/ccv-hub/current;
  index index.html;

  location /api/ {
    proxy_pass http://127.0.0.1:4318;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}

server {
  listen 80;
  server_name ~^ccv-[a-f0-9]{32}\.example\.com$;

  location / {
    proxy_pass http://127.0.0.1:4318;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_buffering off;
    proxy_read_timeout 3600s;
  }
}
