# [INPUT]: 依赖 Nginx、hub-web 静态产物目录、环境变量 CCV_HUB_PUBLIC_HOST/CCV_HUB_AGENT_UPSTREAM 与宿主机 ccv-hub-agent API/bridge 服务
# [OUTPUT]: 对外提供 Hub 静态站点、/api 代理与同 host /viewer/* 反向代理样例
# [POS]: deploy 目录的 Nginx 平台适配模板，负责传统 VPS 静态 Web 与 Agent bridge 接入
# [PROTOCOL]: 变更时更新此头部，然后检查 CLAUDE.md
map $http_upgrade $connection_upgrade {
  default upgrade;
  '' close;
}

server {
  listen 80;
  server_name ${CCV_HUB_PUBLIC_HOST};

  root ${CCV_HUB_WEB_ROOT};
  index index.html;

  location /api/ {
    proxy_pass ${CCV_HUB_AGENT_UPSTREAM};
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-CCV-Hub-Agent-Token ${CCV_HUB_AGENT_PROXY_TOKEN};
  }

  location ${CCV_HUB_VIEWER_PATH_PREFIX}/ {
    proxy_pass ${CCV_HUB_AGENT_UPSTREAM};
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-CCV-Hub-Agent-Token ${CCV_HUB_AGENT_PROXY_TOKEN};
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_buffering off;
    proxy_read_timeout 3600s;
  }

  location / {
    try_files $uri $uri/ /index.html;
  }
}
